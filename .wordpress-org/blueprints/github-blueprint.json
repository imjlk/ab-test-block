			"code": "<?php\nif ( ! function_exists( 'wp_insert_post' ) ) {\n\trequire_once 'wordpress/wp-load.php';\n}\n\n$post_id = 1001;\n$post_content = <<<'HTML'\n<!-- wp:abtest-block/test {\"experimentId\":\"playground_demo\",\"variantCount\":2,\"weights\":{\"a\":50,\"b\":50},\"previewQueryKey\":\"ab_playground_demo\",\"stickyAssignment\":true,\"winnerMode\":\"off\",\"automaticMetric\":\"ctr\",\"minimumImpressionsPerVariant\":100,\"minimumClicksPerVariant\":1,\"evaluationWindowDays\":14,\"lockWinnerAfterSelection\":true,\"trackImpressions\":true,\"trackClicks\":true,\"emitBrowserEvents\":true,\"emitKexpLayer\":false,\"emitDataLayer\":false,\"emitClarityHook\":false,\"blockInstanceId\":\"playdemo01\"} -->\n<!-- wp:abtest-block/variant {\"variantKey\":\"a\",\"variantLabel\":\"Variant A\"} -->\n<div class=\"wp-block-abtest-block-variant\" data-abtest-variant=\"a\" data-variant-label=\"Variant A\">\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Variant A: Free shipping framing</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Use this editor-ready sample to compare headline framing. The CTA below is explicitly marked with <code>abtest-cta</code> so the plugin's click tracking is easy to inspect.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button {\"url\":\"#variant-a\",\"className\":\"abtest-cta\"} -->\n<div class=\"wp-block-button abtest-cta\"><a class=\"wp-block-button__link wp-element-button\" href=\"#variant-a\">Explore Variant A</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:abtest-block/variant -->\n\n<!-- wp:abtest-block/variant {\"variantKey\":\"b\",\"variantLabel\":\"Variant B\"} -->\n<div class=\"wp-block-abtest-block-variant\" data-abtest-variant=\"b\" data-variant-label=\"Variant B\">\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Variant B: Limited-time framing</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>This second variant uses urgency-focused copy with the same structural CTA. Publish the post and preview the front end to test assignment, impression, and click behavior.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button {\"url\":\"#variant-b\",\"className\":\"abtest-cta\"} -->\n<div class=\"wp-block-button abtest-cta\"><a class=\"wp-block-button__link wp-element-button\" href=\"#variant-b\">Explore Variant B</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:abtest-block/variant -->\n<!-- /wp:abtest-block/test -->\nHTML;\n\n$postarr = array(\n\t'ID' => $post_id,\n\t'import_id' => $post_id,\n\t'post_author' => 1,\n\t'post_content' => $post_content,\n\t'post_excerpt' => 'Seeded editor demo for the A/B Test block plugin.',\n\t'post_name' => 'ab-test-block-playground-demo',\n\t'post_status' => 'publish',\n\t'post_title' => 'A/B Test Block Playground Demo',\n\t'post_type' => 'post',\n);\n\nif ( get_post( $post_id ) ) {\n\twp_update_post( $postarr );\n} else {\n\twp_insert_post( $postarr );\n}\n"
