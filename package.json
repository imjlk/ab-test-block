{
	"name": "ab-test-block",
	"version": "0.2.0",
	"packageManager": "bun@1.3.10",
	"description": "Block Directory-ready A/B and A/B/C experiment block plugin for Gutenberg.",
	"author": "imjlk",
	"license": "GPL-2.0-or-later",
	"main": "build/blocks/test/index.js",
	"files": [
		"ab-test-block.php",
		"build",
		"readme.txt",
		"README.md",
		"package.json"
	],
	"scripts": {
		"sync-types": "tsx scripts/sync-types-to-block-json.ts",
		"sync-rest": "tsx scripts/sync-rest-contracts.ts",
		"release:sync-version-files": "tsx scripts/sync-release-version.ts",
		"release:prepare": "sampo release && bun run release:sync-version-files",
		"build": "bun run sync-types && bun run sync-rest && wp-scripts build --experimental-modules",
		"start": "bun run sync-types && bun run sync-rest && wp-scripts start --experimental-modules",
		"dev": "bun run start",
		"plugin-zip": "bun run build && wp-scripts plugin-zip --root-folder=ab-test-block",
		"env:start": "wp-env start",
		"env:status": "wp-env status",
		"env:stop": "wp-env stop",
		"env:destroy": "printf 'y\\n' | wp-env destroy",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint": "bun run lint:js && bun run lint:css",
		"format": "wp-scripts format",
		"typecheck": "bun run sync-types && bun run sync-rest && tsc --noEmit"
	},
	"devDependencies": {
		"@wp-typia/block-types": "^0.1.3",
		"@wp-typia/create": "^0.4.0",
		"@wp-typia/rest": "^0.2.0",
		"ajv": "^8.18.0",
		"@types/wordpress__block-editor": "^11.5.17",
		"@types/wordpress__blocks": "^12.5.18",
		"@wordpress/browserslist-config": "^6.42.0",
		"@wordpress/env": "^10.0.0",
		"@wordpress/scripts": "^30.22.0",
		"@typia/unplugin": "^12.0.1",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"typia": "^12.0.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.42.0",
		"@wordpress/block-editor": "^15.2.0",
		"@wordpress/blocks": "^15.2.0",
		"@wordpress/components": "^30.2.0",
		"@wordpress/data": "^10.32.0",
		"@wordpress/element": "^6.29.0",
		"@wordpress/i18n": "^6.2.0",
		"@wordpress/interactivity": "^6.29.0"
	}
}
