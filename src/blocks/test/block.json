{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "abtest-block/test",
	"version": "0.3.3",
	"title": "A/B Test",
	"category": "design",
	"icon": "randomize",
	"description": "Create A/B or A/B/C experiments with weighted delivery and winner selection.",
	"keywords": [
		"ab test",
		"experiment",
		"split test"
	],
	"supports": {
		"html": false,
		"anchor": true,
		"className": true,
		"interactivity": true
	},
	"allowedBlocks": [
		"abtest-block/variant"
	],
	"textdomain": "ab-test-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"attributes": {
		"experimentId": {
			"type": "string",
			"default": "experiment"
		},
		"experimentLabel": {
			"type": "string",
			"default": "Experiment"
		},
		"variantCount": {
			"type": "number",
			"default": 2,
			"enum": [
				2,
				3
			]
		},
		"weights": {
			"type": "object"
		},
		"previewQueryKey": {
			"type": "string",
			"default": "abtest"
		},
		"stickyAssignment": {
			"type": "boolean",
			"default": true
		},
		"stickyScope": {
			"type": "string",
			"default": "instance",
			"enum": [
				"instance",
				"experiment"
			]
		},
		"winnerMode": {
			"type": "string",
			"default": "off",
			"enum": [
				"off",
				"manual",
				"automatic"
			]
		},
		"manualWinner": {
			"type": "string",
			"enum": [
				"a",
				"b",
				"c"
			]
		},
		"automaticMetric": {
			"type": "string",
			"default": "ctr",
			"enum": [
				"ctr"
			]
		},
		"minimumImpressionsPerVariant": {
			"type": "number",
			"default": 100
		},
		"minimumClicksPerVariant": {
			"type": "number",
			"default": 1
		},
		"evaluationWindowDays": {
			"type": "number",
			"default": 14
		},
		"lockWinnerAfterSelection": {
			"type": "boolean",
			"default": true
		},
		"trackImpressions": {
			"type": "boolean",
			"default": true
		},
		"trackClicks": {
			"type": "boolean",
			"default": true
		},
		"emitBrowserEvents": {
			"type": "boolean",
			"default": true
		},
		"emitKexpLayer": {
			"type": "boolean",
			"default": false
		},
		"emitDataLayer": {
			"type": "boolean",
			"default": false
		},
		"emitClarityHook": {
			"type": "boolean",
			"default": false
		},
		"blockInstanceId": {
			"type": "string"
		}
	},
	"example": {
		"attributes": {
			"automaticMetric": "ctr",
			"blockInstanceId": "visualfixture1",
			"emitBrowserEvents": true,
			"emitClarityHook": false,
			"emitDataLayer": false,
			"emitKexpLayer": false,
			"evaluationWindowDays": 14,
			"experimentId": "visual_fixture",
			"experimentLabel": "Visual parity fixture",
			"lockWinnerAfterSelection": true,
			"minimumClicksPerVariant": 1,
			"minimumImpressionsPerVariant": 100,
			"previewQueryKey": "ab_visual_fixture",
			"stickyAssignment": true,
			"stickyScope": "instance",
			"trackClicks": true,
			"trackImpressions": true,
			"variantCount": 2,
			"weights": {
				"a": 50,
				"b": 50,
				"c": 0
			},
			"winnerMode": "off"
		},
		"innerBlocks": [
			{
				"attributes": {
					"variantKey": "a",
					"variantLabel": "Variant A"
				},
				"innerBlocks": [
					{
						"attributes": {
							"content": "Variant A: Free shipping framing",
							"level": 3
						},
						"name": "core/heading"
					},
					{
						"attributes": {
							"content": "Use this canonical fixture to validate editor and front-end parity around shell styling, spacing, and CTA rhythm."
						},
						"name": "core/paragraph"
					},
					{
						"innerBlocks": [
							{
								"attributes": {
									"className": "abtest-cta",
									"text": "Explore Variant A",
									"url": "#variant-a"
								},
								"name": "core/button"
							}
						],
						"name": "core/buttons"
					}
				],
				"name": "abtest-block/variant"
			},
			{
				"attributes": {
					"variantKey": "b",
					"variantLabel": "Variant B"
				},
				"innerBlocks": [
					{
						"attributes": {
							"content": "Variant B: Limited-time framing",
							"level": 3
						},
						"name": "core/heading"
					},
					{
						"attributes": {
							"content": "This alternate variant keeps the same structure while changing the copy so the two active states stay visually comparable."
						},
						"name": "core/paragraph"
					},
					{
						"innerBlocks": [
							{
								"attributes": {
									"className": "abtest-cta",
									"text": "Explore Variant B",
									"url": "#variant-b"
								},
								"name": "core/button"
							}
						],
						"name": "core/buttons"
					}
				],
				"name": "abtest-block/variant"
			}
		],
		"viewportWidth": 960
	}
}
