{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "abtest-block/variant",
	"version": "0.3.2",
	"title": "Variant",
	"category": "design",
	"icon": "excerpt-view",
	"description": "Internal variant block for the A/B Test block.",
	"parent": [
		"abtest-block/test"
	],
	"supports": {
		"html": false,
		"inserter": false,
		"reusable": false
	},
	"textdomain": "ab-test-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"attributes": {
		"variantKey": {
			"type": "string",
			"default": "a",
			"enum": [
				"a",
				"b",
				"c"
			]
		},
		"variantLabel": {
			"type": "string",
			"default": "Variant A"
		}
	},
	"example": {
		"attributes": {
			"variantKey": "a",
			"variantLabel": "Variant A"
		},
		"innerBlocks": [
			{
				"attributes": {
					"content": "Variant A: Free shipping framing",
					"level": 3
				},
				"name": "core/heading"
			},
			{
				"attributes": {
					"content": "Use this canonical fixture to validate editor and front-end parity around shell styling, spacing, and CTA rhythm."
				},
				"name": "core/paragraph"
			},
			{
				"innerBlocks": [
					{
						"attributes": {
							"className": "abtest-cta",
							"text": "Explore Variant A",
							"url": "#variant-a"
						},
						"name": "core/button"
					}
				],
				"name": "core/buttons"
			}
		]
	}
}
